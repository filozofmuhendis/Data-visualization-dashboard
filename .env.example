# Application
app_name=MSA Dashboard
app_version=1.0.0
debug=false
host=0.0.0.0
port=8000
reload=false

# Database
database_url=sqlite:///./msa_dashboard.db
database_echo=false

# Security
secret_key=change-this-in-production
algorithm=HS256
access_token_expire_minutes=30

# CORS (JSON list)
cors_origins=["https://your-domain.com","http://localhost:8050"]

# Logging
log_level=INFO
log_format=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# MQTT (optional)
mqtt_broker_host=localhost
mqtt_broker_port=1883
mqtt_username=
mqtt_password=

# Uploads
upload_directory=./uploads
max_file_size=10485760

# Redis (optional)
redis_url=