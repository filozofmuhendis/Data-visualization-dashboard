app_name=MSA Dashboard
app_version=1.0.0
debug=false

# Server
host=0.0.0.0
port=8000
reload=false

# Database (bind-mounted SQLite)
database_url=sqlite:///./msa_dashboard.db
database_echo=false

# Security
secret_key=local-dev-not-secret
algorithm=HS256
access_token_expire_minutes=30

# CORS
cors_origins=["http://localhost","http://localhost:8050"]

# Uploads
upload_directory=./uploads

# MQTT (optional; defaults are fine)
mqtt_broker_host=localhost
mqtt_broker_port=1883

# Logging
log_level=INFO